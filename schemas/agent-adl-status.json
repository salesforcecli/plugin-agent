{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/AgentAdlStatusResult",
  "definitions": {
    "AgentAdlStatusResult": {
      "$ref": "#/definitions/IndexingStatusResponse"
    },
    "IndexingStatusResponse": {
      "type": "object",
      "properties": {
        "indexingStatus": {
          "type": "object",
          "properties": {
            "libraryId": {
              "type": "string"
            },
            "status": {
              "type": "string"
            },
            "currentStage": {
              "type": "string"
            },
            "stageDetails": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/StageDetail"
              }
            },
            "lastUpdatedAt": {
              "type": "number"
            }
          },
          "required": ["libraryId", "status"],
          "additionalProperties": false
        }
      },
      "required": ["indexingStatus"],
      "additionalProperties": false
    },
    "StageDetail": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "completedAt": {
          "type": "number"
        },
        "startedAt": {
          "type": "number"
        },
        "error": {
          "type": "string"
        }
      },
      "required": ["name", "status"],
      "additionalProperties": false
    }
  }
}
