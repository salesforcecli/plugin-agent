{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/AgentPublishAuthoringBundleResult",
  "definitions": {
    "AgentPublishAuthoringBundleResult": {
      "type": "object",
      "properties": {
        "success": {
          "type": "boolean"
        },
        "botDeveloperName": {
          "type": "string"
        },
        "errors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "retrievedComponents": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "deployedComponents": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "summary": {
          "type": "object",
          "properties": {
            "retrieved": {
              "type": "number"
            },
            "deployed": {
              "type": "number"
            }
          },
          "required": ["retrieved", "deployed"],
          "additionalProperties": false
        }
      },
      "required": ["success"],
      "additionalProperties": false
    }
  }
}
